<!DOCTYPE html>
<html lang="da">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Café Zea</title>

    <!-- 1. Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- 2. Dit globale tema -->
    <link rel="stylesheet" href="~/css/site.css" />

    <!-- 3. Bootstrap-overrides -->
    <link rel="stylesheet" href="~/css/bootstrap-overrides.css" />

    <!-- 4. Komponenter -->
    <link rel="stylesheet" href="~/css/components/navbar.css" />
    <link rel="stylesheet" href="~/css/components/buttons.css" />
    <link rel="stylesheet" href="~/css/components/cards.css" />
    <link rel="stylesheet" href="~/css/components/forms.css" />
    <link rel="stylesheet" href="~/css/components/tables.css" />
    <link rel="stylesheet" href="~/css/components/badges.css" />
    <link rel="stylesheet" href="~/css/components/alerts.css" />
    <link rel="stylesheet" href="~/css/components/hero.css" />
    <link rel="stylesheet" href="~/css/components/animations.css" />
    <link rel="stylesheet" href="~/css/components/ui-components.css" />

    @RenderSection("Styles", required: false)
</head>

<body>
    <!-- NAVBAR -->
    <header>
        <nav class="navbar navbar-expand-lg cz-navbar">
            <div class="container">

                <!-- Brand -->
                <a class="navbar-brand" asp-page="/Index">Café Zea</a>

                <!-- Mobile toggle -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- Links -->
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav ms-auto">

                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Menu/Index">Menu</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Index">Forside</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Privacy">Privatliv</a>
                        </li>

                        @if (!User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Logon/Login">Log ind</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item nav-link">
                                Bruger: <b>@User.Identity.Name</b>
                            </li>
                        }

                    </ul>
                </div>

            </div>
        </nav>
    </header>

    <!-- MAIN CONTENT -->
    <main class="container py-4">
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="footer text-muted py-3">
        <div class="container">
            &copy; 2026 - Café Zea
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Dit JS -->
    <script src="~/js/site.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>
