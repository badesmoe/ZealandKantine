@page
@model ZealandKantine.Pages.DailySpecialPages.CreateModel

<div class="container mt-4">

    <div class="card shadow p-4">

        <h1 class="mb-4">🍽️ Opret Dagens Ret</h1>

        <form method="post">

            <div class="mb-3">
                <label class="form-label">Beskrivelse</label>
                <input asp-for="DailySpecial.Description"
                       class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Pris</label>

                <input asp-for="DailySpecial.Price"
                       type="number"
                       step="0.01"
                       min="0"
                       class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Dato</label>

                <input asp-for="DailySpecial.Date"
                       type="date"
                       class="form-control" />
            </div>

            <button type="submit"
                    class="btn btn-primary">
                Gem Dagens Ret
            </button>

        </form>

    </div>

</div>