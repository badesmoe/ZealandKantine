@page
@model ZealandKantine.Pages.Menu.DeleteModel
@{
    ViewData["Title"] = "Opdater Menukort";
}

@if (!Model.Items.Any())
{
    <div class="empty-state">
        <div class="empty-state__icon"></div>
        <h3>Ingen menupunkter fundet</h3>
        <p>Der er ingen aktive menupunkter at opdatere.</p>
        <a asp-page="/Menu/Index" class="btn btn-secondary mt-2">Tilbage til menu</a>
    </div>
}
else
{
    <div class="alert alert-warning mb-4">
        <strong>Advarsel:</strong> Sletning er permanent og kan ikke fortrydes. Bekræft venligst inden du sletter.
    </div>
    <a asp-page="/Menu/Index" class="btn btn-secondary">
        ← Tilbage til menu
    </a>

    <div class="menu-grid">
        @foreach (var group in Model.Items.GroupBy(m => m.Category))
        {
            <div>
                <h2 class="mb-3">@group.Key</h2>
                <div class="menu-category">
                    @foreach (var item in group)
                    {
                        <div class="menu-item" style="position: relative; padding-bottom: 3.5rem;">
                            <span class="menu-item__category">@item.Category</span>
                            <h3 class="menu-item__name">@item.Name</h3>
                            <p class="menu-item__price">@item.Price.ToString("0.00")</p>
                            <form method="post"
                                  asp-page-handler="Update"
                                  style="position: absolute; bottom: 0.75rem; left: 0.75rem;"
                                  onsubmit="return confirm('Er du sikker på, at du vil opdatere »@item.Name«?');">
                                <input type="hidden" name="MenuItem.Id" value="@item.Id" />
                                <input type="hidden" name="MenuItem.Name" value="@item.Name" />
                                <input type="hidden" name="MenuItem.Price" value="@item.Price" />
                                <input type="hidden" name="MenuItem.Category" value="@item.Category" />
                                <input type="hidden" name="MenuItem.IsActive" value="@item.IsActive" />
                                <button type="submit" class="btn btn-primary btn-sm d-flex align-items-center gap-1">
                                     Opdater
                                </button>
                            </form>
                            <form method="post"
                                  asp-page-handler="Delete"
                                  style="position: absolute; bottom: 0.75rem; right: 0.75rem;"
                                  onsubmit="return confirm('Er du sikker på, at du vil slette »@item.Name«? Denne handling kan ikke fortrydes.');">
                                <input type="hidden" name="MenuItem.Id" value="@item.Id" />
                                <button type="submit" class="btn btn-danger btn-sm d-flex align-items-center gap-1">
                                    ✕ Slet
                                </button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}