@page
@model ZealandKantine.Pages.Menu.IndexModel
@{
    ViewData["Title"] = "Menu";
}

<h1>Menu</h1>

@if (Model.TodaysSpecial != null && Model.TodaysSpecial.IsActive)
{
    <div class="daily-special">
        <h3>Dagens ret</h3>
        <p>@Model.TodaysSpecial.Description</p>
        <p>@Model.TodaysSpecial.Price.ToString("0.00") kr.</p>
    </div>
}

@foreach (var item in Model.Items)
{
    <div class="menu-item">
        <h3>@item.Name</h3>
        <p>@item.Description</p>
        <p>@item.Price.ToString("0.00") kr.</p>
    </div>
}