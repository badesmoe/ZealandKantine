@page
@model ZealandKantine.Pages.Logon.LoginModel
@{
    ViewData["Title"] = "Log ind";
}

<div class="container d-flex justify-content-center align-items-center min-vh-100">
    <div class="card shadow-lg border-0 rounded-4 p-4" style="width: 100%; max-width: 420px;">

        <div class="text-center mb-4">
            <h1 class="h3 fw-bold">Zealand Kantine</h1>
            <p class="text-muted">Log ind for at fortsætte</p>
        </div>

        <div class="error-message text-center">
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <span>@Model.ErrorMessage</span>
            }
        </div>

        <form method="post">

            <div class="form-group mb-3">
                <label asp-for="Name" class="form-label fw-semibold">
                    Brugernavn
                </label>

                <input asp-for="Name"
                       class="form-control form-control-lg rounded-3"
                       placeholder="Indtast brugernavn" />
            </div>

            <div class="form-group mb-4">
                <label asp-for="Password" class="form-label fw-semibold">
                    Kodeord
                </label>

                <input asp-for="Password"
                       type="password"
                       class="form-control form-control-lg rounded-3"
                       placeholder="Indtast kodeord" />
            </div>

            <div class="d-grid">
                <button type="submit"
                        class="btn btn-primary btn-lg rounded-3">
                    Log ind
                </button>
            </div>

        </form>
    </div>
</div>